{
  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase@latest", "--access-token", "YOUR_SUPABASE_ACCESS_TOKEN"],
      "_comment": "Get your access token from: https://supabase.com/dashboard/account/tokens"
    },
    "google-drive": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gdrive"],
      "env": {
        "GOOGLE_CLIENT_ID": "YOUR_GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET": "YOUR_GOOGLE_CLIENT_SECRET",
        "GOOGLE_REFRESH_TOKEN": "YOUR_GOOGLE_REFRESH_TOKEN"
      },
      "_comment": "Set up OAuth at: https://console.cloud.google.com"
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "_comment": "Browser automation — no auth required"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "_comment": "Up-to-date library docs — no auth required"
    }
  },
  "_instructions": "Copy this file to .mcp.json and fill in YOUR_ values. Remove MCP blocks you don't use. .mcp.json is gitignored so your tokens stay local."
}
