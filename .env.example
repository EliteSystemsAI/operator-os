# Elite Systems AI — Content OS Credentials
# Copy this file to .env and fill in your real values.
# Never commit .env to git.

# Meta Ads
META_ACCESS_TOKEN=your_meta_access_token
META_AD_ACCOUNT_ID=your_meta_ad_account_id
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# GoHighLevel
GHL_API_KEY=your_ghl_api_key
GHL_LOCATION_ID=your_ghl_location_id
GHL_USER_ID=your_ghl_user_id
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_AGENCY_API_KEY=your_ghl_agency_api_key

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_GROUP_ID=your_telegram_group_id

# ClickUp
CLICKUP_API_TOKEN=your_clickup_personal_api_token

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
STRIPE_API_KEY=sk_live_your_stripe_api_key

# OpenAI
OPENAI_API_KEY=sk-your_openai_api_key

# Gemini / Google GenAI
GEMINI_API_KEY=your_gemini_api_key

# xAI
XAI_API_KEY=your_xai_api_key

# Vercel
VERCEL_TOKEN=your_vercel_token
VERCEL_TEAM_ID=your_vercel_team_id
VERCEL_PROJECT_ID=your_vercel_project_id
VERCEL_PROD_DOMAIN=your_production_domain

# Xero
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret
XERO_REDIRECT_URI=https://your-redirect-uri/callback

# OpenClaw
OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token
OPENCLAW_DEFAULT_MODEL=claude-sonnet-4-6

# Google Drive — Operator OS
GDRIVE_ROOT_ID=your_gdrive_root_folder_id
GDRIVE_COMPARISONS_ID=your_gdrive_comparisons_folder_id
GDRIVE_CAROUSELS_ID=your_gdrive_carousels_folder_id
GDRIVE_SCRIPTS_ID=your_gdrive_scripts_folder_id
GDRIVE_ADS_ID=your_gdrive_ads_folder_id
GDRIVE_BRAND_ID=your_gdrive_brand_folder_id

# Slack
SLACK_BOT_TOKEN=xoxb-your_slack_bot_token
SLACK_USER_TOKEN=xoxp-your_slack_user_token

# Instagram / Meta
IG_ACCESS_TOKEN=your_instagram_access_token
IG_ACCOUNT_ID=your_instagram_account_id

# Deepgram (voice transcription)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Claude Code OAuth (long-lived token for Mac Mini bot)
# Generate with: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-your_token_here

# Command bot tuning (optional — defaults shown)
# COMMAND_GENERAL_MODEL=sonnet
# COMMAND_GENERAL_MAX_TURNS=40
# COMMAND_GENERAL_MAX_BUDGET=5.00
